{
  "name": "tabula-orbis-kmz-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/preprocess-kmz.mjs && vite",
    "build": "node scripts/preprocess-kmz.mjs && vite build",
    "preprocess:kmz": "node scripts/preprocess-kmz.mjs",
    "preview": "vite preview",
    "backend:dev": "python -m uvicorn server.app.main:app --reload --port 8000",
    "backend:migrate": "python -m alembic -c server/alembic.ini upgrade head",
    "backend:import-kmz": "python -m server.scripts.import_kmz",
    "backend:test": "python -m pytest server/tests",
    "start:dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^3.1.1",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}
